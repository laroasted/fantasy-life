{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/update-stocks",
      "schedule": "0 2 * * 1-5"
    },
    {
      "path": "/api/cron/update-sports",
      "schedule": "0 6 * * *"
    }
  ]
}